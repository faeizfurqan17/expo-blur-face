# macOS
.DS_Store

# Editors
.vscode/
.idea/
jsconfig.json

# ─── Xcode ────────────────────────────────────────────────────────────────────
# NOTE: Do NOT ignore the top-level build/ — that's the compiled JS output
# that npm publishes. Only ignore Xcode-specific build artefacts below.
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata
*.xccheckout
*.moved-aside
DerivedData
*.hmap
*.ipa
*.xcuserstate
project.xcworkspace

# ─── Android ──────────────────────────────────────────────────────────────────
.classpath
.cxx
.gradle
.project
.settings
local.properties
android.iml
# Gradle build output (compiled artefacts — not source)
android/build/

# ─── Example app — generated native dirs (prebuild output, not source) ────────
example/android/
example/ios/
example/.expo/
example/node_modules/

# ─── CocoaPods ────────────────────────────────────────────────────────────────
ios/Pods/
# (example/ios is already ignored above)

# ─── Ruby ─────────────────────────────────────────────────────────────────────
example/vendor/
.bundle/

# ─── Node ─────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ─── Expo ─────────────────────────────────────────────────────────────────────
.expo/

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo
